# =========================================================
# Bunyod-market bot uchun namunaviy .env fayl
# =========================================================
# Eslatma:
# - BOT_TOKEN majburiy.
# - Database URLlardan kamida bittasi majburiy.
# - ADMIN_ID ixtiyoriy (birinchi super_admin ni belgilash uchun).

# -------------------------
# Telegram bot tokenlari
# -------------------------
# Asosiy token (tavsiya etiladi)
BOT_TOKEN=

# Mijoz (client) boti uchun alohida token.
# Bo'sh qoldirilsa mijoz ham BOT_TOKEN bilan ishlaydi.
CLIENT_BOT_TOKEN=

# Legacy/fallback token nomlari (staff bot uchun BOT_TOKEN -> TELEGRAM_BOT_TOKEN -> TOKEN ketma-ketligida o‘qiydi)
TELEGRAM_BOT_TOKEN=
TOKEN=

# -------------------------
# Admin sozlamalari
# -------------------------
# Super admin Telegram user ID (masalan: 123456789)
ADMIN_ID=

# -------------------------
# Ma'lumotlar bazasi (PostgreSQL)
# -------------------------
# Asosiy ulanish URL manzili (tavsiya etiladi)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Muqobil URL (Railway/Public URL holatlari uchun)
DATABASE_PUBLIC_URL=

# Yana bir muqobil URL nomi
POSTGRES_URL=

# -------------------------
# Legacy/o‘tgan konfiguratsiyalar
# -------------------------
# Quyidagilar hozirgi kodda ishlatilmaydi, faqat eski deploylar bilan moslik uchun qoldirilgan.
ADMIN_BOT_TOKEN=
REDIS_URL=
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=
PORT=
